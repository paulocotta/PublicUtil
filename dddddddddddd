BEGIN
	/*
	* Utilizado por: Task schedule (db_ctrl)
	* Mata conexoes alheias
	*/
	DECLARE `_done` TINYINT(1) DEFAULT FALSE;
	DECLARE `_id` INT DEFAULT NULL;
	DECLARE `_crs` CURSOR FOR (
		SELECT `information_schema`.`PROCESSLIST`.`ID`
		FROM `information_schema`.`PROCESSLIST`
		WHERE `information_schema`.`PROCESSLIST`.`USER` NOT IN ('root','unauthenticated user','event_scheduler')
		AND `information_schema`.`PROCESSLIST`.`COMMAND` NOT IN ('Query')
	);
	DECLARE CONTINUE HANDLER FOR NOT FOUND BEGIN SET `_done`=TRUE; END;
	DECLARE CONTINUE HANDLER FOR SQLEXCEPTION BEGIN END;
	OPEN `_crs`;
	read_loop:LOOP
		FETCH `_crs` INTO `_id`;
		IF ( `_done` ) THEN LEAVE read_loop; END IF;
		KILL `_id`;
	END LOOP read_loop;
	CLOSE `_crs`;
	COMMIT;
END
